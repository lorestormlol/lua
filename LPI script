local function ActionBtn(txt, color, fn)
    local b = Instance.new("TextButton", GlobalFrame)
    b.Size = UDim2.new(1, 0, 0, 35)
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 9
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() fn(b) end)
    return b
end

ActionBtn("ERASE WORLD", Color3.fromRGB(120, 0, 0), function()
    for _, item in pairs(workspace:GetChildren()) do
        if not item:IsA("Camera") and not item:IsA("Script") and not Players:GetPlayerFromCharacter(item) then
            forceDelete(item)
        end
    end
end)

ActionBtn("WIPE ALL INVS", Color3.fromRGB(0, 100, 150), function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            for _, t in pairs(p.Backpack:GetChildren()) do forceDelete(t) end
            if p.Character then
                for _, t in pairs(p.Character:GetChildren()) do
                    if t:IsA("Tool") then forceDelete(t) end
                end
            end
        end
    end
end)

local LockBtn = ActionBtn("Lock Server: OFF", Color3.fromRGB(60, 60, 60), function(btn)
    ServerLocked = not ServerLocked
    btn.Text = ServerLocked and "Lock Server: ON" or "Lock Server: OFF"
    btn.BackgroundColor3 = ServerLocked and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(60, 60, 60)
end)

local IslandBtn = ActionBtn("Island Prot: OFF", Color3.fromRGB(60, 60, 60), function(btn)
    IslandProtector = not IslandProtector
    btn.Text = IslandProtector and "Island Prot: ON" or "Island Prot: OFF"
    btn.BackgroundColor3 = IslandProtector and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(60, 60, 60)
end)

task.spawn(function()
    while task.wait(0.5) do
        if CurrentRemote then
            Title.Text = "Status: " .. (ServerLocked and "Locked" or "Active") .. (IslandProtector and " | PROT 🛡️" or "")
            Title.TextColor3 = ServerLocked and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(0, 255, 150)
        else
            Title.Text = "Remote Missing"
            Title.TextColor3 = Color3.fromRGB(255, 150, 0)
        end

        if IslandProtector then
            local base = workspace:FindFirstChild("Baseplate")
            if base then
                local bPos = base:GetPivot().Position
                local bSize = base:IsA("Model") and base:GetExtentsSize() or base.Size

                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local pPos = p.Character.HumanoidRootPart.Position
                        
                        local diffX = math.abs(pPos.X - bPos.X)
                        local diffZ = math.abs(pPos.Z - bPos.Z)
                        local diffY = pPos.Y - bPos.Y 

                        if diffX < (bSize.X/2 + 5) and diffZ < (bSize.Z/2 + 5) and diffY < 30 and diffY > -10 then
                            forceDelete(p.Character)
                            for _, t in pairs(p.Backpack:GetChildren()) do forceDelete(t) end
                        end
                    end
                end
            end
        end
    end
end)

local function Refresh()
    local cols = {{S = InvCol, M = "Inv"}, {S = CharCol, M = "Char"}, {S = KickCol, M = "Kick"}}
    for _, col in pairs(cols) do
        for _, c in pairs(col.S:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local b = Instance.new("TextButton", col.S)
                b.Size = UDim2.new(1, -10, 0, 28)
                b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                b.Text = p.Name
                b.TextColor3 = Color3.new(1, 1, 1)
                b.Font = Enum.Font.Gotham
                b.TextSize = 10
                Instance.new("UICorner", b)

                b.MouseButton1Click:Connect(function()
                    if col.M == "Inv" then
                        for _, t in pairs(p.Backpack:GetChildren()) do forceDelete(t) end
                        if p.Character then for _, t in pairs(p.Character:GetChildren()) do if t:IsA("Tool") then forceDelete(t) end end end
                    elseif col.M == "Char" then
                        if p.Character then forceDelete(p.Character) end
                    elseif col.M == "Kick" then
                        forceDelete(p)
                    end
                end)
            end
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    if ServerLocked then task.wait(0.5) forceDelete(player) end
    Refresh()
end)
Players.PlayerRemoving:Connect(Refresh)
Refresh()

