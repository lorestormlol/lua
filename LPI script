local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local CurrentRemote = nil
local ServerLocked = false 
local IslandProtector = false

task.spawn(function()
    while task.wait(1) do
        local name = "RemoteDelete"
        local found = LocalPlayer.Backpack:FindFirstChild(name, true) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(name, true))
        CurrentRemote = found
    end
end)

local function forceDelete(obj)
    if CurrentRemote and obj then
        task.spawn(function() 
            pcall(function() CurrentRemote:InvokeServer(obj) end) 
        end)
    end
end

