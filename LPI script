local function CreateColumn(xPos, title)
    local lab = Instance.new("TextLabel", Main)
    lab.Size = UDim2.new(0, 120, 0, 20)
    lab.Position = UDim2.new(0, xPos, 0, 45)
    lab.Text = title
    lab.TextColor3 = Color3.fromRGB(150, 150, 150)
    lab.BackgroundTransparency = 1
    lab.Font = Enum.Font.GothamSemibold
    lab.TextSize = 10

    local scroll = Instance.new("ScrollingFrame", Main)
    scroll.Size = UDim2.new(0, 120, 0, 340)
    scroll.Position = UDim2.new(0, xPos, 0, 70)
    scroll.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 2
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y 
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 3)
    return scroll
end

